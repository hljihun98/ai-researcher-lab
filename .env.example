# AI Researcher Lab 환경변수 템플릿
# 이 파일을 .env로 복사한 뒤 값을 채우세요. (.env는 커밋되지 않습니다.)
# ⚠️ 실제 키는 절대 소스코드/커밋에 넣지 마세요.

# 실시간 백엔드(기본). Google AI Studio에서 발급한 Gemini 키.
GEMINI_API_KEY=

# Gemini 모델 (선택). 기본값은 config.GEMINI_MODEL(gemini-2.0-flash-lite, 무료 하루한도 큼).
# GEMINI_MODEL=gemini-2.0-flash-lite

# 데모 모드. "1"이면 어떤 키도 없이 캔드 응답으로 전체 흐름을 시연합니다.
# 모든 키보다 우선합니다.
AI_RESEARCHER_DEMO_MODE=0

# Gemini 무료 등급용 라이트 모드. "1"이면 세션당 LLM 호출을 5회로 제한합니다.
AI_RESEARCHER_LITE=1

# 웹 요청이 배포 서버 타임아웃에 도달하지 않도록 하는 안전 한도(선택).
AI_RESEARCHER_SESSION_BUDGET_SECONDS=60
GEMINI_REQUEST_TIMEOUT_SECONDS=20
GEMINI_MAX_ATTEMPTS=1

# (선택) Anthropic 폴백. GEMINI_API_KEY가 없을 때만 사용됩니다.
# ANTHROPIC_API_KEY=sk-ant-...
